#!/usr/bin/env bash
# GestorIA.app — lanza Electron con splash de carga (sin Terminal)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
APP_DIR="$PROJECT_ROOT/app"
ELECTRON_APP="$APP_DIR/node_modules/electron/dist/Electron.app"
ELECTRON_BIN="$ELECTRON_APP/Contents/MacOS/Electron"

if [ ! -f "$ELECTRON_BIN" ]; then
  osascript -e "display alert \"GestorIA\" message \"Electron no encontrado.\nEjecuta 'npm install' en la carpeta app/.\" as critical"
  exit 1
fi

# Firma ad-hoc: elimina quarantine del binario Electron
codesign --force --deep --sign - "$ELECTRON_APP" 2>/dev/null || true

# Pasar parámetros via fichero temp — 'open' no transmite variables de entorno
printf 'GESTORIA_LAUNCHER=1\nGESTORIA_PROJECT_ROOT=%s\n' "$PROJECT_ROOT" \
  > /tmp/.gestoria_launcher

# Exponer ruta de Docker a procesos GUI lanzados desde Finder
launchctl setenv GESTORIA_EXTRA_PATH \
  "/Applications/Docker.app/Contents/Resources/bin:/usr/local/bin:/opt/homebrew/bin:/opt/homebrew/sbin" \
  2>/dev/null || true

# Lanzar Electron fuera del sandbox de esta .app (open -n da permisos completos)
open -n "$ELECTRON_APP" --args "$APP_DIR/electron/main.cjs"
